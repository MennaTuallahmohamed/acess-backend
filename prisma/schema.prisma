generator client {
  provider = "prisma-client-js"
}

//generator erd {
 // provider = "prisma-erd-generator"
  //output   = "./ERD.png"
//}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
}

model User {
  id                       Int                             @id @default(autoincrement())
  fullName                 String?
  username                 String?                         @unique
  passwordHash             String
  phone                    String?
  isActive                 Boolean                         @default(true)
  status                   UserStatus                      @default(ACTIVE)
  roleId                   Int
  createdAt                DateTime                        @default(now())
  updatedAt                DateTime                        @updatedAt
  email                    String?                         @unique
  firstName                String?
  jobTitle                 String?
  lastName                 String?
  notes                    String?
  officeNumber             String?
  region                   String?

  auditLogs                AuditLog[]
  movements                DeviceMovement[]
  statusChanges            DeviceStatusHistory[]
  inspections              Inspection[]
  reportedInspectionIssues InspectionIssue[]               @relation("InspectionIssueReportedBy")
  issueSolutionActions     InspectionIssueSolutionAction[] @relation("IssueSolutionActionBy")

  assignedTasks            InspectionTask[]                @relation("TaskAssignedTo")
  createdTasks             InspectionTask[]                @relation("TaskCreatedBy")
  assignedTaskItems        InspectionTaskItem[]            @relation("TaskItemAssignedTo")
  completedTaskItems       InspectionTaskItem[]            @relation("TaskItemCompletedBy")

  createdCampaigns         InspectionCampaign[]            @relation("CampaignCreatedBy")
  assignedCampaigns        InspectionCampaign[]            @relation("CampaignAssignedTo")

  maintenanceLogs          MaintenanceLog[]

  technicianActivityLogs   TechnicianActivityLog[]

  morphoRepairs            DeviceMorphoRepair[]            @relation("MorphoRepairBy")

  createdReplacements      DeviceReplacement[]             @relation("DeviceReplacementBy")
  approvedReplacements     DeviceReplacement[]             @relation("DeviceReplacementApprovedBy")

  role                     Role                            @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@index([status])
  @@index([isActive])
  @@index([username])
  @@index([email])
}

model Location {
  id        Int      @id @default(autoincrement())
  building  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cluster   String
  direction String?
  excelId   String   @unique
  lane      String?
  type      String?
  zone      String?

  devices   Device[]
  gates     Gate[]

  replacementFrom DeviceReplacement[] @relation("ReplacementFromLocation")
  replacementTo   DeviceReplacement[] @relation("ReplacementToLocation")

  @@index([cluster])
  @@index([building])
  @@index([zone])
  @@index([direction])
  @@index([lane])
  @@index([type])
}

model DeviceType {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  assetType   AssetType @default(DEVICE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  devices     Device[]
  issues      Issue[]

  @@index([assetType])
}

model Device {
  id               Int                   @id @default(autoincrement())
  deviceCode       String                @unique
  deviceName       String
  barcode          String                @unique
  serialNumber     String?               @unique
  manufacturer     String?
  modelNumber      String?

  currentStatus    DeviceCurrentStatus   @default(OK)
  lifecycleStatus  DeviceLifecycleStatus @default(ACTIVE)

  installDate      DateTime?
  lastInspectionAt DateTime?

  deviceTypeId     Int
  locationId       Int

  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  excelDate        String?
  excelStatus      String?
  firmware         String?
  ipAddress        String?

  assetType        AssetType             @default(DEVICE)

  // بيانات قديمة مؤقتة عشان الداتا القديمة ما تتأثرش
  gateNo           String?
  secretCode       String?               @unique
  gateDirection    String?
  gateZone         String?
  gateCluster      String?
  gateBuilding     String?

  deviceType       DeviceType            @relation(fields: [deviceTypeId], references: [id])
  location         Location              @relation(fields: [locationId], references: [id])

  movements        DeviceMovement[]
  statusHistory    DeviceStatusHistory[]
  inspections      Inspection[]
  tasks            InspectionTask[]
  taskItems        InspectionTaskItem[]
  maintenanceLogs  MaintenanceLog[]

  morphoRepairs    DeviceMorphoRepair[]

  replacementAsOld DeviceReplacement[]    @relation("OldDeviceReplacement")
  replacementAsNew DeviceReplacement[]    @relation("NewDeviceReplacement")

  activityLogs     TechnicianActivityLog[]

  @@index([deviceTypeId])
  @@index([locationId])
  @@index([barcode])
  @@index([secretCode])
  @@index([assetType])
  @@index([gateNo])
  @@index([gateCluster])
  @@index([gateBuilding])
  @@index([ipAddress])
  @@index([currentStatus])
  @@index([lifecycleStatus])
  @@index([lastInspectionAt])
}

model Gate {
  id               Int                 @id @default(autoincrement())

  gateNo           String
  secretCode       String              @unique

  cluster          String
  building         String
  zone             String?
  direction        String?
  lane             String?
  type             String?
  excelId          String?             @unique

  locationId       Int?
  status           GateStatus          @default(ACTIVE)
  currentStatus    DeviceCurrentStatus @default(OK)

  notes            String?
  lastInspectionAt DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  location         Location?           @relation(fields: [locationId], references: [id])
  inspections      Inspection[]
  tasks            InspectionTask[]
  taskItems        InspectionTaskItem[]

  activityLogs     TechnicianActivityLog[]

  @@index([gateNo])
  @@index([secretCode])
  @@index([cluster])
  @@index([building])
  @@index([zone])
  @@index([direction])
  @@index([locationId])
  @@index([status])
  @@index([currentStatus])
  @@index([lastInspectionAt])
}

model InspectionCampaign {
  id            Int              @id @default(autoincrement())
  title         String
  description   String?
  createdById   Int
  assignedToId  Int?
  assetType     AssetType?
  taskKind      TaskKind?
  status        CampaignStatus   @default(DRAFT)
  priority      TaskPriority     @default(MEDIUM)
  startDate     DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  createdBy     User             @relation("CampaignCreatedBy", fields: [createdById], references: [id])
  assignedTo    User?            @relation("CampaignAssignedTo", fields: [assignedToId], references: [id])
  tasks         InspectionTask[]

  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
  @@index([assetType])
  @@index([taskKind])
  @@index([dueDate])
}

model InspectionTask {
  id                  Int              @id @default(autoincrement())

  campaignId          Int?
  deviceId            Int?
  gateId              Int?

  assignedToId        Int?
  createdById         Int

  scheduledDate       DateTime
  dueDate             DateTime?
  frequency           String?

  status              TaskStatus       @default(PENDING)
  priority            TaskPriority     @default(MEDIUM)
  assetType           AssetType        @default(DEVICE)

  taskKind            TaskKind         @default(SINGLE_ASSET)
  requiresScan        Boolean          @default(true)
  requiresLocation    Boolean          @default(false)

  title               String?
  notes               String?

  startedAt           DateTime?
  completedAt         DateTime?

  adminReview         TaskReviewStatus @default(PENDING_REVIEW)
  adminNote           String?

  totalItems          Int              @default(0)
  completedItems      Int              @default(0)
  issueItems          Int              @default(0)
  notReachableItems   Int              @default(0)
  remainingItems      Int              @default(0)
  progressPercent     Float            @default(0)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  campaign            InspectionCampaign? @relation(fields: [campaignId], references: [id])
  assignedTo          User?            @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdBy           User             @relation("TaskCreatedBy", fields: [createdById], references: [id])

  device              Device?          @relation(fields: [deviceId], references: [id])
  gate                Gate?            @relation(fields: [gateId], references: [id])

  inspections         Inspection[]
  items               InspectionTaskItem[]

  activityLogs        TechnicianActivityLog[]

  @@index([campaignId])
  @@index([deviceId])
  @@index([gateId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([assetType])
  @@index([taskKind])
  @@index([dueDate])
  @@index([scheduledDate])
}

model InspectionTaskItem {
  id                    Int                  @id @default(autoincrement())

  taskId                Int
  deviceId              Int?
  gateId                Int?

  assignedToId          Int?
  completedById         Int?

  status                TaskItemStatus       @default(PENDING)
  inspectionId          Int?                 @unique

  routeOrder            Int?

  notes                 String?
  completionNote        String?
  issueFound            Boolean              @default(false)

  scannedCode           String?

  startedAt             DateTime?
  inspectedAt           DateTime?

  completedLatitude     Float?
  completedLongitude    Float?
  completedLocationText String?

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  task                  InspectionTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  device                Device?              @relation(fields: [deviceId], references: [id])
  gate                  Gate?                @relation(fields: [gateId], references: [id])

  assignedTo            User?                @relation("TaskItemAssignedTo", fields: [assignedToId], references: [id])
  completedBy           User?                @relation("TaskItemCompletedBy", fields: [completedById], references: [id])

  inspection            Inspection?          @relation(fields: [inspectionId], references: [id])

  morphoRepairs         DeviceMorphoRepair[]
  replacements          DeviceReplacement[]
  activityLogs          TechnicianActivityLog[]

  @@unique([taskId, deviceId])
  @@unique([taskId, gateId])

  @@index([taskId])
  @@index([deviceId])
  @@index([gateId])
  @@index([assignedToId])
  @@index([completedById])
  @@index([status])
  @@index([routeOrder])
  @@index([inspectedAt])
}

model Inspection {
  id               Int                             @id @default(autoincrement())

  deviceId         Int?
  gateId           Int?
  technicianId     Int
  taskId           Int?

  inspectionStatus InspectionStatus
  issueReason      String?
  notes            String?

  latitude         Float?
  longitude        Float?
  locationText     String?

  inspectedAt      DateTime                        @default(now())
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  device           Device?                         @relation(fields: [deviceId], references: [id])
  gate             Gate?                           @relation(fields: [gateId], references: [id])
  task             InspectionTask?                 @relation(fields: [taskId], references: [id])
  technician       User                            @relation(fields: [technicianId], references: [id])

  taskItem         InspectionTaskItem?

  images           InspectionImage[]
  inspectionIssues InspectionIssue[]
  solutionActions  InspectionIssueSolutionAction[]

  morphoRepairs    DeviceMorphoRepair[]
  replacements     DeviceReplacement[]
  activityLogs     TechnicianActivityLog[]

  @@index([deviceId])
  @@index([gateId])
  @@index([technicianId])
  @@index([taskId])
  @@index([inspectionStatus])
  @@index([inspectedAt])
}

model InspectionImage {
  id           Int        @id @default(autoincrement())
  inspectionId Int
  imageUrl     String
  imageType    String?
  createdAt    DateTime   @default(now())

  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
}

model MaintenanceLog {
  id               Int               @id @default(autoincrement())

  deviceId         Int
  createdById      Int

  status           MaintenanceStatus @default(OPEN)

  issueReason      String?
  notes            String?

  sentOut          Boolean           @default(false)
  maintenancePlace String?
  externalVendor   String?

  startedAt        DateTime?
  completedAt      DateTime?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  createdBy        User              @relation(fields: [createdById], references: [id])
  device           Device            @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@index([createdById])
  @@index([status])
}

model DeviceMovement {
  id             Int          @id @default(autoincrement())

  deviceId       Int
  movedById      Int

  movementType   MovementType

  fromLocationId Int?
  toLocationId   Int?

  fromText       String?
  toText         String?
  reason         String?

  movedAt        DateTime     @default(now())
  createdAt      DateTime     @default(now())

  device         Device       @relation(fields: [deviceId], references: [id])
  movedBy        User         @relation(fields: [movedById], references: [id])

  @@index([deviceId])
  @@index([movedById])
  @@index([movementType])
  @@index([movedAt])
}

model DeviceStatusHistory {
  id          Int                  @id @default(autoincrement())

  deviceId    Int
  oldStatus   DeviceCurrentStatus?
  newStatus   DeviceCurrentStatus
  changedById Int
  note        String?

  changedAt   DateTime             @default(now())

  changedBy   User                 @relation(fields: [changedById], references: [id])
  device      Device               @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@index([changedById])
  @@index([newStatus])
  @@index([changedAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())

  userId     Int?
  action     String
  entityType String
  entityId   Int?
  details    String?

  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([action])
  @@index([createdAt])
}

model IssueCategory {
  id          Int        @id @default(autoincrement())

  name        String     @unique
  code        String?    @unique
  assetType   AssetType?
  description String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  issues      Issue[]

  @@index([assetType])
}

model Issue {
  id              Int               @id @default(autoincrement())

  issueCode       String            @unique
  title           String
  description     String?

  severity        IssueSeverity     @default(MEDIUM)
  status          IssueStatus       @default(ACTIVE)

  assetType       AssetType         @default(DEVICE)

  categoryId      Int
  deviceTypeId    Int?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  inspectionItems InspectionIssue[]

  category        IssueCategory     @relation(fields: [categoryId], references: [id])
  deviceType      DeviceType?       @relation(fields: [deviceTypeId], references: [id])

  solutions       IssueSolution[]

  @@index([categoryId])
  @@index([deviceTypeId])
  @@index([assetType])
  @@index([status])
  @@index([title])
  @@index([severity])
}

model IssueSolution {
  id           Int                             @id @default(autoincrement())

  solutionCode String?                         @unique
  issueId      Int

  title        String
  description  String?

  stepOrder    Int
  isRequired   Boolean                         @default(true)
  status       SolutionStatus                  @default(ACTIVE)

  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt

  actions      InspectionIssueSolutionAction[]

  issue        Issue                           @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([issueId, stepOrder])
  @@index([issueId])
  @@index([stepOrder])
  @@index([status])
}

model InspectionIssue {
  id               Int                             @id @default(autoincrement())

  inspectionId     Int
  issueId          Int
  reportedById     Int

  status           InspectionIssueStatus           @default(OPEN)

  notes            String?
  resolvedAt       DateTime?
  unresolvedReason String?

  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  inspection       Inspection                      @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  issue            Issue                           @relation(fields: [issueId], references: [id])
  reportedBy       User                            @relation("InspectionIssueReportedBy", fields: [reportedById], references: [id])

  actions          InspectionIssueSolutionAction[]

  @@index([inspectionId])
  @@index([issueId])
  @@index([reportedById])
  @@index([status])
}

model InspectionIssueSolutionAction {
  id                Int                   @id @default(autoincrement())

  inspectionId      Int
  inspectionIssueId Int
  solutionId        Int
  technicianId      Int

  status            ActionExecutionStatus @default(PENDING)
  note              String?
  doneAt            DateTime?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  inspection        Inspection            @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  inspectionIssue   InspectionIssue       @relation(fields: [inspectionIssueId], references: [id], onDelete: Cascade)
  solution          IssueSolution         @relation(fields: [solutionId], references: [id])
  technician        User                  @relation("IssueSolutionActionBy", fields: [technicianId], references: [id])

  @@unique([inspectionIssueId, solutionId])

  @@index([inspectionId])
  @@index([inspectionIssueId])
  @@index([solutionId])
  @@index([technicianId])
  @@index([status])
}

model TechnicianActivityLog {
  id             Int                  @id @default(autoincrement())

  userId         Int
  action         TechnicianActionType

  deviceId       Int?
  gateId         Int?
  taskId         Int?
  taskItemId     Int?
  inspectionId   Int?
  replacementId  Int?
  morphoRepairId Int?

  title          String?
  message        String?

  beforeStatus   String?
  afterStatus    String?

  latitude       Float?
  longitude      Float?
  locationText   String?

  metadata       Json?

  createdAt      DateTime             @default(now())

  user           User                 @relation(fields: [userId], references: [id])
  device         Device?              @relation(fields: [deviceId], references: [id])
  gate           Gate?                @relation(fields: [gateId], references: [id])
  task           InspectionTask?      @relation(fields: [taskId], references: [id])
  taskItem       InspectionTaskItem?  @relation(fields: [taskItemId], references: [id])
  inspection     Inspection?          @relation(fields: [inspectionId], references: [id])
  replacement    DeviceReplacement?   @relation(fields: [replacementId], references: [id])
  morphoRepair   DeviceMorphoRepair?  @relation(fields: [morphoRepairId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([deviceId])
  @@index([gateId])
  @@index([taskId])
  @@index([taskItemId])
  @@index([inspectionId])
  @@index([replacementId])
  @@index([morphoRepairId])
  @@index([createdAt])
}

model DeviceMorphoRepair {
  id             Int                 @id @default(autoincrement())

  deviceId       Int
  technicianId   Int

  taskItemId     Int?
  inspectionId   Int?

  status         MorphoRepairStatus  @default(REPORTED_FIXED)

  oldStatus      DeviceCurrentStatus?
  newStatus      DeviceCurrentStatus @default(OK)

  source         String              @default("MORPHO_APP")

  notes          String?
  proofImageUrl  String?

  fixedAt        DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  device         Device              @relation(fields: [deviceId], references: [id])
  technician     User                @relation("MorphoRepairBy", fields: [technicianId], references: [id])

  taskItem       InspectionTaskItem? @relation(fields: [taskItemId], references: [id])
  inspection     Inspection?         @relation(fields: [inspectionId], references: [id])

  activityLogs   TechnicianActivityLog[]

  @@index([deviceId])
  @@index([technicianId])
  @@index([taskItemId])
  @@index([inspectionId])
  @@index([status])
  @@index([fixedAt])
}

model DeviceReplacement {
  id              Int                     @id @default(autoincrement())

  oldDeviceId     Int
  newDeviceId     Int

  replacedById    Int
  approvedById    Int?

  taskItemId      Int?
  inspectionId    Int?

  fromLocationId  Int?
  toLocationId    Int?

  oldIpAddress    String?
  newIpAddress    String?
  keepSameIp      Boolean                 @default(true)

  reason          String?
  notes           String?

  status          DeviceReplacementStatus @default(COMPLETED)

  replacedAt      DateTime                @default(now())
  approvedAt      DateTime?

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  oldDevice       Device                  @relation("OldDeviceReplacement", fields: [oldDeviceId], references: [id])
  newDevice       Device                  @relation("NewDeviceReplacement", fields: [newDeviceId], references: [id])

  replacedBy      User                    @relation("DeviceReplacementBy", fields: [replacedById], references: [id])
  approvedBy      User?                   @relation("DeviceReplacementApprovedBy", fields: [approvedById], references: [id])

  taskItem        InspectionTaskItem?     @relation(fields: [taskItemId], references: [id])
  inspection      Inspection?             @relation(fields: [inspectionId], references: [id])

  fromLocation    Location?               @relation("ReplacementFromLocation", fields: [fromLocationId], references: [id])
  toLocation      Location?               @relation("ReplacementToLocation", fields: [toLocationId], references: [id])

  activityLogs    TechnicianActivityLog[]

  @@index([oldDeviceId])
  @@index([newDeviceId])
  @@index([replacedById])
  @@index([approvedById])
  @@index([taskItemId])
  @@index([inspectionId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([oldIpAddress])
  @@index([newIpAddress])
  @@index([status])
  @@index([replacedAt])
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AssetType {
  DEVICE
  GATE
  SOFTWARE
}

enum GateStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum DeviceCurrentStatus {
  OK
  NEEDS_MAINTENANCE
  UNDER_MAINTENANCE
  OUT_OF_SERVICE
}

enum DeviceLifecycleStatus {
  ACTIVE
  REPLACED
  RETIRED
  ARCHIVED
  LOST
}

enum InspectionStatus {
  OK
  NOT_OK
  PARTIAL
  NOT_REACHABLE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskItemStatus {
  PENDING
  IN_PROGRESS
  DONE
  ISSUE_FOUND
  NOT_REACHABLE
  SKIPPED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  SENT_OUT
  RETURNED
}

enum MovementType {
  TRANSFER
  SENT_TO_MAINTENANCE
  RETURNED_FROM_MAINTENANCE
  RELOCATED
  REPLACED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  ACTIVE
  INACTIVE
}

enum SolutionStatus {
  ACTIVE
  INACTIVE
}

enum InspectionIssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  UNRESOLVED
  SKIPPED
}

enum ActionExecutionStatus {
  PENDING
  DONE
  FAILED
  SKIPPED
}

enum TaskKind {
  SINGLE_ASSET
  GLOBAL_ROUTE
  MAINTENANCE_CHECK
  REPLACEMENT_ROUTE
  SOFTWARE_CHECK
}

enum TechnicianActionType {
  TASK_STARTED
  TASK_ITEM_STARTED
  TASK_ITEM_DONE
  TASK_ITEM_ISSUE_FOUND
  TASK_ITEM_NOT_REACHABLE
  INSPECTION_CREATED
  MORPHO_FIXED
  DEVICE_REPLACED
  DEVICE_STATUS_CHANGED
  NOTE_ADDED
  ADMIN_REVIEWED
}

enum MorphoRepairStatus {
  REPORTED_FIXED
  CONFIRMED_BY_ADMIN
  REJECTED
  REOPENED
}

enum DeviceReplacementStatus {
  DRAFT
  COMPLETED
  APPROVED
  CANCELLED
}